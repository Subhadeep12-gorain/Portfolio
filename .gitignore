# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/

# Local environment files (Crucial: prevents pushing API keys/secrets to GitHub)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editors & IDEs
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swp

# Linter caches
.eslintcache

# Vite cache
.vite/

# Large media files (videos)
*.mp4
*.webm
*.ogg
*.mov

# Unused/Old files directory
src/unused_files/

# Agent skills and configurations
.agent/

# Scratch/Temporary files
temp.js

# Unused root-level static files directory
/assets/

# Personal CV / PDF documents
*.pdf

# Old HTML files
index-old.html
*-old.*

# Explicitly ignore public videos directory
public/videos/

# Design system
design-system/
